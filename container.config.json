{
  "readinessProbe": {
    "initialDelaySeconds": 90,
    "periodSeconds": 10,
    "timeoutSeconds": 5,
    "failureThreshold": 3,
    "successThreshold": 1,
    "probeHandler": {
      "httpGet": {
        "path": "/",
        "port": 8101,
        "scheme": "HTTP"
      }
    }
  },
  "livenessProbe": {
    "initialDelaySeconds": 90,
    "periodSeconds": 10,
    "timeoutSeconds": 5,
    "failureThreshold": 3,
    "successThreshold": 1,
    "probeHandler": {
      "httpGet": {
        "path": "/",
        "port": 8101,
        "scheme": "HTTP"
      }
    }
  }
}